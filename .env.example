# Website Configuration
URL=https://your-tfc-website.com/

# CSS Selectors
USERNAME_SELECTOR="#username"
PASSWORD_SELECTOR="#password"
SUBMIT_SELECTOR="#kc-login"

# Credentials
USERNAME="your-email@example.com"
PASSWORD="your-password"

# TFC
AMENITY_TYPE_ID="10"
TENNIS_COURT_1=8
TENNIS_COURT_2=10
GUESTS="1"
AMENITY_RESERVATION_TYPE="TR"

# Scheduler Configuration
# Cron format: "second minute hour day month weekday"
# Examples:
#   "0 8 * * *"     = 8:00 AM daily
#   "0 9 * * 1"     = 9:00 AM every Monday  
#   "0 */6 * * *"   = Every 6 hours
#   "0 18 * * 5"    = 6:00 PM every Friday

SCHEDULE_GET_TOKEN="0 8 * * *"           # Get token at 8:00 AM daily
SCHEDULE_RESERVE="0 9 * * 1"             # Reserve court at 9:00 AM every Monday
TOKEN_REFRESH_INTERVAL="0 */6 * * *"     # Refresh token every 6 hours
ENABLE_AUTO_RESERVE="true"               # Enable automatic reservations

# Access Token (will be automatically updated by get-token script)
ACCESS_TOKEN=""
